{
    "name": "justbetter/laravel-magento-prices",
    "description": "Generic package to push prices to Magento",
    "type": "package",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "justbetter/laravel-magento-async": "^1.0",
        "justbetter/laravel-magento-client": "^2.6.1",
        "justbetter/laravel-magento-products": "^1.7",
        "laravel/framework": "^12.0|^13.0",
        "spatie/laravel-activitylog": "^4.8"
    },
    "require-dev": {
        "doctrine/dbal": "^3.6",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.11|^11.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpunit/phpunit": "^13.0",
        "rector/rector": "^2.3"
    },
    "authors": [
        {
            "name": "Vincent Boon",
            "email": "vincent@justbetter.nl",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "JustBetter\\MagentoPrices\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JustBetter\\MagentoPrices\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan --memory-limit=256M",
        "style": "pint --test",
        "quality": [
            "@style",
            "@analyse",
            "@test",
            "@coverage",
            "@rector"
        ],
        "fix-style": "pint",
        "coverage": "XDEBUG_MODE=coverage php -d memory_limit=2G vendor/bin/phpunit --coverage-text --only-summary-for-coverage-text | grep -c \"100.00%\" | grep -q \"^3$\" && exit 0 || exit 1",
        "rector": "rector process --dry-run"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JustBetter\\MagentoPrices\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
